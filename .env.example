# Copy to .env and adjust for your deployment.
# Every value here has a sensible default in docker-compose.yml; only
# override what you need.

# ─── Branding ────────────────────────────────────────────────────────────
PROVIDER_NAME=Demo National ID Provider
CONSUMER_NAME=Demo Shop

# ─── Key rotation cadence (ms) ───────────────────────────────────────────
# 60 000 ms is good for a live demo: rotations happen often enough that
# an audience can watch them. Lengthen to 86 400 000 (24 h) for realism.
KEY_TIMESPAN_MS=60000

# ─── Public URLs — what the user's browser will see ──────────────────────
# These are injected into the consumer's HTML so the browser knows where
# to redirect (easy flow) and where to open the broker WebSocket. They
# MUST be reachable from end-user machines, not just from inside the
# docker network.
#
# Local docker on your laptop:
PROVIDER_WEB_URL=http://localhost:3002
WS_PUBLIC_URL=ws://localhost:3011/terminal
#
# Example for a server behind real domains + TLS-terminating proxy:
# PROVIDER_WEB_URL=https://provider.example.com
# WS_PUBLIC_URL=wss://consumer.example.com/terminal

# ─── Internal URL — how containers reach the key server ──────────────────
# Default uses the docker-compose service name. Override to point at an
# externally hosted key server.
SERVER_INTERNAL_URL=http://server:4000

# ─── Published host ports ────────────────────────────────────────────────
# Change if something else on the host already uses these.
SERVER_PORT=4000
PROVIDER_PORT=3002
CONSUMER_PORT=3001
WS_PORT=3011
